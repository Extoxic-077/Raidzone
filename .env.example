# ══════════════════════════════════════════════════════════════════════════════
# NexVault — шаблон переменных окружения
# Скопируй в .env и заполни реальными значениями.
# .env добавлен в .gitignore — никогда не коммить реальные секреты!
# ══════════════════════════════════════════════════════════════════════════════

# ── База данных (PostgreSQL) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexvault
DB_USER=nexvault
DB_PASSWORD=nexvault          # на продакшне — сильный случайный пароль

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Минимум 32 символа. Генерация: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-at-least-32-characters-long

# ── CORS ──────────────────────────────────────────────────────────────────────
# Список разрешённых origins через запятую (без пробелов)
# Локально: http://localhost:3000,http://localhost:8080
# Продакшн: https://nexvault.digital
CORS_ALLOWED_ORIGINS=https://nexvault.digital,http://localhost:3000

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# App Password: Google Account → Безопасность → Пароли приложений
# Если оставить "placeholder" — OTP будет выводиться в лог вместо отправки
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx    # 16-символьный App Password
MAIL_FROM=NexVault <your-email@gmail.com>

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Создать: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Redirect URI: https://nexvault.digital/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# Создать: discord.com/developers/applications → OAuth2
# Redirect URI: https://nexvault.digital/api/v1/auth/oauth/discord/callback
DISCORD_CLIENT_ID=123456789012345678
DISCORD_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OAuth redirect base URL ───────────────────────────────────────────────────
# Продакшн: https://nexvault.digital
# Локально с ngrok: https://xxxx-xx-xx.ngrok-free.app
OAUTH_REDIRECT_BASE_URL=https://nexvault.digital

# ── Stripe ────────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
# Тест: sk_test_... / Продакшн: sk_live_...
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Razorpay ──────────────────────────────────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys
# Тест: rzp_test_... / Продакшн: rzp_live_...
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Coinbase Commerce ─────────────────────────────────────────────────────────
# commerce.coinbase.com → Settings → API keys
COINBASE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COINBASE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Upload directory ──────────────────────────────────────────────────────────
# Локально: ./uploads (относительно папки backend/)
# Продакшн: /home/user/nexvault-uploads (абсолютный путь)
UPLOAD_DIR=./uploads
